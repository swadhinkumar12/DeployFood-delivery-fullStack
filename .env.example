# ========================================
# Food Delivery App - Environment Variables
# Copy this to .env and fill with real values
# ========================================

# DATABASE (Railway provides these automatically)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=food_delivery_db
DB_USER=root
DB_PASSWORD=123456

# BACKEND (Java Spring Boot)
JAVA_PORT=8080
JWT_SECRET=your-super-secret-jwt-key-min-256-bits-change-this-in-production!!
JWT_EXPIRATION=86400000

# FRONTEND React API URL
VITE_API_BASE_URL=http://localhost:8080/api

# CORS allowed origins (comma-separated for multiple)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
